{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext", // Garante que o TS gere código moderno
    "moduleResolution": "bundler", // Essencial para o Vite entender os imports do node_modules
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}